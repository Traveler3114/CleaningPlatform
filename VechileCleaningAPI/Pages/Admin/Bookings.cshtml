@page
@model VechileCleaningAPI.Pages.Admin.BookingsModel
@{
    ViewData["Title"] = "Bookings";
}

<div class="page-header">
    <h1>Bookings</h1>
    <form method="get" class="date-form">
        <label for="date">Select Date:</label>
        <input type="date" id="date" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" onchange="this.form.submit()" class="date-input" />
        <button type="submit" name="all" value="true" class="btn btn-sm">Show All</button>
    </form>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

@if (Model.Bookings.Count == 0)
{
    <div class="alert alert-info">No bookings found.</div>
}
else
{
    <table class="admin-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Phone</th>
                <th>Date</th>
                <th>Hour</th>
                <th>Status</th>
                <th>Update Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model.Bookings)
            {
                <tr>
                    <td>@booking.Id</td>
                    <td>@booking.CustomerName</td>
                    <td>@booking.Phone</td>
                    <td>@booking.Date.ToString("yyyy-MM-dd")</td>
                    <td>@booking.Hour:00</td>
                    <td><span class="badge badge-@booking.Status.ToLower()">@booking.Status</span></td>
                    <td>
                        <form method="post" asp-page-handler="UpdateStatus" class="inline-form">
                            <input type="hidden" name="id" value="@booking.Id" />
                            <input type="hidden" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="all" value="@Model.ShowAll.ToString().ToLower()" />
                            <select name="status" class="status-select">
                                @foreach (var statusOpt in new[] { "Reserved", "Cancelled", "Completed" })
                                {
                                    if (booking.Status == statusOpt)
                                    {
                                        <option value="@statusOpt" selected>@statusOpt</option>
                                    }
                                    else
                                    {
                                        <option value="@statusOpt">@statusOpt</option>
                                    }
                                }
                            </select>
                            <button type="submit" class="btn btn-sm">Save</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
