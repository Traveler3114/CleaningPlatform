<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vehicle Cleaning Admin</title>
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body>
    <header class="admin-header">
        <div class="header-inner">
            <span class="brand">🚗 Vehicle Cleaning Admin</span>
            <nav class="main-nav">
                <a href="/" class="nav-link">Daily View</a>
                <a href="/Bookings" class="nav-link">Bookings</a>
                <a href="/Schedule" class="nav-link">Schedule</a>
            </nav>
        </div>
    </header>
    <main class="admin-main">
        @RenderBody()
    </main>
    <footer class="admin-footer">
        <p>&copy; @DateTime.Now.Year Vehicle Cleaning Admin</p>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
