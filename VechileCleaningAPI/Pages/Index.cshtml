@page
@model VechileCleaningAPI.Pages.IndexModel
@{
    ViewData["Title"] = "Daily View";
}

<div class="page-header">
    <h1>Daily View</h1>
    <form method="get" class="date-form">
        <label for="date">Select Date:</label>
        <input type="date" id="date" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" onchange="this.form.submit()" class="date-input" />
    </form>
</div>

@if (Model.Slots.Count == 0)
{
    <div class="alert alert-info">No slots available for this date (day is closed or no schedule found).</div>
}
else
{
    <table class="admin-table">
        <thead>
            <tr>
                <th>Hour</th>
                <th>Capacity</th>
                <th>Booked</th>
                <th>Available</th>
                <th>Status</th>
                <th>Override</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var slot in Model.Slots)
            {
                <tr class="@(slot.IsClosed ? "row-closed" : slot.Available == 0 ? "row-full" : "")">
                    <td>@slot.Hour:00</td>
                    <td>@slot.Capacity</td>
                    <td>@slot.Booked</td>
                    <td>@slot.Available</td>
                    <td>
                        @if (slot.IsClosed)
                        {
                            <span class="badge badge-closed">Closed</span>
                        }
                        else if (slot.Available == 0)
                        {
                            <span class="badge badge-full">Full</span>
                        }
                        else
                        {
                            <span class="badge badge-open">Open</span>
                        }
                    </td>
                    <td>
                        <form method="post" asp-page-handler="Override" class="override-form">
                            <input type="hidden" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="hour" value="@slot.Hour" />
                            <input type="number" name="capacity" placeholder="Capacity" min="0" max="99" value="@slot.Capacity" class="small-input" />
                            <label class="checkbox-label">
                                <input type="checkbox" name="isClosed" value="true" @(slot.IsClosed ? "checked" : "") /> Close
                            </label>
                            <button type="submit" class="btn btn-sm">Set</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (Model.Bookings.Count > 0)
{
    <h2 class="section-title">Bookings for @Model.SelectedDate.ToString("dddd, MMMM d yyyy")</h2>
    <table class="admin-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Phone</th>
                <th>Hour</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model.Bookings)
            {
                <tr>
                    <td>@booking.CustomerName</td>
                    <td>@booking.Phone</td>
                    <td>@booking.Hour:00</td>
                    <td><span class="badge badge-@booking.Status.ToLower()">@booking.Status</span></td>
                </tr>
            }
        </tbody>
    </table>
}
