@page
@model CleaningPlatformAPI.Pages.Admin.BookingsModel
@{
    ViewData["Title"] = "Bookings";
    ViewData["ActivePage"] = "bookings";
}

<div class="page-header">
    <h1>Bookings</h1>
    <div class="date-form">
        @if (User.HasPermission(PermissionKeys.ActionsBookingCreate))
        {
            <button type="button" class="btn btn-sm" onclick="document.getElementById('new-booking-panel').style.display = document.getElementById('new-booking-panel').style.display === 'none' ? 'block' : 'none';">New Booking</button>
        }
        <form method="get" style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
            <label for="DateFilter">Select Date:</label>
            <input type="date" id="DateFilter" name="DateFilter"
                   value="@Model.DateFilter?.ToString("yyyy-MM-dd")"
                   class="date-input" />
            <button type="submit" class="btn btn-sm">Filter</button>
            <a asp-page="/Admin/Bookings" class="btn btn-sm">Show All</a>
        </form>
    </div>
</div>


@if (User.HasPermission(PermissionKeys.ActionsBookingCreate))
{
    <section id="new-booking-panel" class="card-lite" style="display:none; margin-bottom:1rem;">
        <h2 class="section-title">Create Admin Booking</h2>
        <form method="post" asp-page-handler="CreateAdmin" class="form-grid two-col">
            <label>
                Client
                <select asp-for="NewBooking.ClientId" id="client-select" class="text-input" required>
                    <option value="">Select client</option>
                    @foreach (var client in Model.Clients)
                    {
                        <option value="@client.Id">@client.ClientName</option>
                    }
                </select>
            </label>
            <label>
                Site
                <select asp-for="NewBooking.SiteId" id="site-select" class="text-input">
                    <option value="">No site</option>
                    @foreach (var site in Model.Sites)
                    {
                        <option value="@site.Id">@site.SiteName (@site.Client.ClientName)</option>
                    }
                </select>
            </label>
            <label>
                Service type
                <select asp-for="NewBooking.ServiceType" class="text-input">
                    <option value="Vehicle">Vehicle</option>
                    <option value="SiteBased">Site Based</option>
                    <option value="Boat">Boat</option>
                </select>
            </label>
            <label>
                Date
                <input asp-for="NewBooking.Date" type="date" class="text-input" required />
            </label>
            <label>
                Hour
                <input asp-for="NewBooking.Hour" type="number" min="0" max="23" class="text-input" required />
            </label>
            <label>
                Initial service
                <select asp-for="NewServiceCatalogId" class="text-input">
                    <option value="">No initial service</option>
                    @foreach (var service in Model.Services)
                    {
                        <option value="@service.Id">@service.Name</option>
                    }
                </select>
            </label>
            <label class="full-span">
                Notes
                <textarea asp-for="NewBooking.Notes" class="text-input"></textarea>
            </label>
            <div class="full-span">
                <button type="submit" class="btn btn-sm">Create Booking</button>
            </div>
        </form>
    </section>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert" style="background:#fce4ec;color:#c62828;border:1px solid #ef9a9a;">
        @Model.ErrorMessage
    </div>
}

@if (!Model.Bookings.Any())
{
    <div class="alert alert-info">No bookings found.</div>
}
else
{
    <table class="admin-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Client</th>
                <th>Date</th>
                <th>Hour</th>
                <th>Status</th>
                <th>Update Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model.Bookings)
            {
                <tr class="booking-row" data-href="@Url.Page("/Admin/BookingDetail", new { id = b.Id })" title="Click to open booking detail">
                    <td><a asp-page="/Admin/BookingDetail" asp-route-id="@b.Id" class="link">@b.Id</a></td>
                    <td>
                        <a asp-page="/Admin/ClientDetail" asp-route-id="@b.ClientId" class="link">
                            @b.ClientName
                        </a>
                    </td>
                    <td>@b.Date.ToString("yyyy-MM-dd")</td>
                    <td>@b.Hour:00</td>
                    <td>
                        <span class="badge badge-@b.Status.ToLower()">@b.Status</span>
                    </td>
                    <td>
                        <form method="post" asp-page-handler="UpdateStatus" class="inline-form">
                            <input type="hidden" name="id" value="@b.Id" />
                            <select name="status" class="status-select" aria-label="Update status for booking @b.Id">
                                @foreach (var s in new[] { "Pending", "Confirmed", "InProgress", "Completed", "Cancelled" })
                                {
                                    if (b.Status == s)
                                    {
                                        <option value="@s" selected="selected">@s</option>
                                    }
                                    else
                                    {
                                        <option value="@s">@s</option>
                                    }
                                }
                            </select>
                            <button type="submit" class="btn btn-sm">Save</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
<script>
(function () {
    const clientSelect = document.getElementById('client-select');
    const siteSelect = document.getElementById('site-select');

    if (clientSelect && siteSelect) {
        clientSelect.addEventListener('change', async function () {
            const clientId = this.value;

            siteSelect.disabled = true;
            siteSelect.innerHTML = '<option value="">No site</option>';

            if (!clientId) {
                siteSelect.disabled = false;
                return;
            }

            try {
                const response = await fetch(`/api/clients/${clientId}/sites`, { credentials: 'include' });
                const result = await response.json();
                const sites = result?.success ? (result.data || []) : [];
                const activeSites = sites.filter(s => s.isActive);

                siteSelect.innerHTML = '<option value="">No site</option>';

                if (activeSites.length > 0) {
                    activeSites.forEach(s => {
                        const opt = document.createElement('option');
                        opt.value = s.id;
                        opt.textContent = `${s.siteName} (${s.siteType ?? 'Other'})`;
                        siteSelect.appendChild(opt);
                    });
                } else {
                    siteSelect.innerHTML = '<option value="" disabled>No sites for this client</option>';
                }
            } catch {
                siteSelect.innerHTML = '<option value="" disabled>No sites for this client</option>';
            } finally {
                siteSelect.disabled = false;
            }
        });
    }

    document.querySelectorAll('.booking-row').forEach(row => {
        row.style.cursor = 'pointer';
        row.addEventListener('click', (event) => {
            if (event.target.closest('a, button, select, input, form, label')) {
                return;
            }
            const href = row.dataset.href;
            if (href) {
                window.location.href = href;
            }
        });
    });
})();
</script>
}
