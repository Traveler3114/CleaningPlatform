@page
@model CleaningPlatformAPI.Pages.Admin.BookingsModel
@{
    ViewData["Title"] = "Bookings";
}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:2rem;">
    <h1>Bookings</h1>
    <form method="get" style="display:flex; gap:0.5rem; align-items:center;">
        <input type="date" asp-for="DateFilter" style="padding:0.4rem; border:1px solid #ccc; border-radius:4px;" />
        <button type="submit" class="btn-admin">Filter</button>
    </form>
</div>

<table class="admin-table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Customer</th>
            <th>Date & Time</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var b in Model.Bookings)
        {
            <tr>
                <td><strong>#@b.Id</strong></td>
                <td>@b.CustomerName</td>
                <td>@b.Date.ToShortDateString() at @b.Hour:00</td>
                <td><span class="status-badge">@b.Status</span></td>
                <td>
                    <a asp-page="/Admin/BookingDetail" asp-route-id="@b.Id" class="btn-admin">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>