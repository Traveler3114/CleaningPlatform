@page
@model CleaningPlatformAPI.Pages.Admin.BookingsModel
@{
    ViewData["Title"] = "Bookings";
}
<h1>Bookings</h1>
<form method="get">
    <label>Date filter</label>
    <input type="date" asp-for="DateFilter" />
    <button type="submit">Apply</button>
    <a asp-page="/Admin/Bookings">Show all</a>
</form>
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)) { <p style="color:#b00020;">@Model.ErrorMessage</p> }
<table>
<thead><tr><th>ID</th><th>Customer</th><th>Date</th><th>Status</th><th></th></tr></thead>
<tbody>
@foreach (var b in Model.Bookings)
{
    <tr>
        <td><a asp-page="/Admin/BookingDetail" asp-route-id="@b.Id">@b.Id</a></td>
        <td>@b.CustomerName</td>
        <td>@b.Date.ToString("yyyy-MM-dd") @b.Hour:00</td>
        <td>@b.Status</td>
        <td>
            <form method="post" asp-page-handler="UpdateStatus">
                <input type="hidden" name="id" value="@b.Id" />
                <input type="hidden" asp-for="DateFilter" />
                <select name="status">
                    <option>Pending</option><option>Confirmed</option><option>InProgress</option><option>Completed</option><option>Cancelled</option>
                </select>
                <button type="submit">Update</button>
            </form>
        </td>
    </tr>
}
</tbody>
</table>
