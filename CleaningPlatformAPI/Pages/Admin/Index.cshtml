@page
@model CleaningPlatformAPI.Pages.Admin.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Daily View";
    ViewData["ActivePage"] = "daily";
}
<div class="page-header">
    <h1>Daily View</h1>
    <form method="get" class="date-form">
        <label for="SelectedDate">Date</label>
        <input id="SelectedDate" type="date" asp-for="SelectedDate" class="date-input" onchange="this.form.submit()" />
    </form>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<section class="kpi-grid">
    <div class="kpi-card"><span>Revenue MTD</span><strong>@(Model.DashboardSummary.MonthlyRevenue?.TotalRevenue.ToString("C") ?? "—")</strong></div>
    <div class="kpi-card"><span>Overdue invoices</span><strong>@Model.DashboardSummary.OverdueInvoices.TotalOverdueAmount.ToString("C")</strong><small>@Model.DashboardSummary.OverdueInvoices.OverdueInvoiceCount invoices</small></div>
    <div class="kpi-card"><span>Completion rate</span><strong>@(Model.DashboardSummary.CompletionRate?.CompletionRatePct?.ToString("0.0") ?? "0")%</strong></div>
    <div class="kpi-card"><span>Top client</span><strong>@(Model.DashboardSummary.TopClient?.ClientName ?? "—")</strong></div>
    <div class="kpi-card"><span>Pending today</span><strong>@Model.KpiPending</strong></div>
    <div class="kpi-card"><span>Confirmed today</span><strong>@Model.KpiConfirmed</strong></div>
</section>

<section class="detail-section">
    <h2 class="section-title">Bookings</h2>
    @if (Model.TodaysBookings.Count == 0)
    {
        <div class="alert alert-info">No bookings found for selected date.</div>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr><th>ID</th><th>Client</th><th>Time</th><th>Status</th><th>Assigned Employees</th></tr>
            </thead>
            <tbody>
                @foreach (var b in Model.TodaysBookings)
                {
                    <tr><td>#@b.Id</td><td>@b.ClientName</td><td>@b.Hour:00</td><td><span class="badge badge-@b.Status.ToLower()">@b.Status</span></td><td>@string.Join(", ", b.AssignedEmployees.Select(e => e.FullName))</td></tr>
                }
            </tbody>
        </table>
    }
</section>

<section class="detail-section">
    <h2 class="section-title">Slots</h2>
    <table class="admin-table">
        <thead><tr><th>Hour</th><th>Capacity</th><th>Booked</th><th>Available</th><th>State</th></tr></thead>
        <tbody>
            @foreach (var s in Model.Slots)
            {
                var isFull = !s.IsClosed && s.Available <= 0;
                var state = s.IsClosed ? "Closed" : isFull ? "Full" : "Open";
                var stateClass = s.IsClosed ? "closed" : isFull ? "full" : "open";
                <tr class="@(s.IsClosed ? "row-closed" : isFull ? "row-full" : "")">
                    <td>@s.Hour:00</td><td>@s.Capacity</td><td>@s.Booked</td><td>@s.Available</td>
                    <td><span class="badge badge-@stateClass">@state</span></td>
                </tr>
            }
        </tbody>
    </table>
</section>