@page
@model CleaningPlatformAPI.Pages.Admin.KanbanModel
@using System.Security.Claims
@using CleaningPlatformAPI.Common
@using CleaningPlatformAPI.Extensions
@{
    ViewData["Title"] = "Calendar";
    ViewData["ActivePage"] = "kanban";

    var weekStart = Model.WeekStartDate;
    var today = DateTime.UtcNow.Date;

    string StatusCss(string status) => status.ToLower() switch
    {
        "pending"    => "resource-card--pending",
        "confirmed"  => "resource-card--confirmed",
        "inprogress" => "resource-card--inprogress",
        "completed"  => "resource-card--completed",
        _            => "resource-card--cancelled"
    };

    string ChipCss(string status) => status.ToLower() switch
    {
        "pending"    => "resource-chip--pending",
        "confirmed"  => "resource-chip--confirmed",
        "inprogress" => "resource-chip--inprogress",
        "completed"  => "resource-chip--completed",
        _            => "resource-chip--cancelled"
    };
}

@* ═══════════════════════════════════════════════════════════════
   EMPLOYEE VIEW — completely unchanged
   ═══════════════════════════════════════════════════════════════ *@
@if (Model.IsEmployeeView)
{
    <div class="page-header">
        <h1>My Schedule</h1>
    </div>

    @foreach (var day in Model.Board.Days)
    {
        if (!day.Bookings.Any()) continue;

        <h3 style="margin:1rem 0 0.5rem; color:#3949ab; font-size:0.95rem;">
            @day.DayLabel @(day.IsToday ? "— Today" : "")
        </h3>

        foreach (var card in day.Bookings.OrderBy(c => c.Hour))
        {
            var cssStatus = card.Status.ToLower();
            <div class="emp-task-card emp-task-card--@cssStatus">
                <div class="emp-task-card__header">
                    <span class="emp-task-card__title">
                        @card.Hour:00 — @card.ClientName
                    </span>
                    <span class="badge badge-@cssStatus">@card.Status</span>
                </div>
                <div class="emp-task-card__meta">
                    @if (!string.IsNullOrWhiteSpace(card.SiteName))
                    {
                        <div>📍 @card.SiteName — @card.SiteAddress</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(card.ClientPhone))
                    {
                        <div>📞 @card.ClientPhone</div>
                    }
                    <div>@card.ServiceType · @card.ServicesCount service(s)</div>
                    @if (card.HasSop)
                    {
                        <div style="margin-top:0.3rem;">
                            SOP: @card.SopCompletionPct% complete
                            <div class="cal-sop-bar" style="margin-top:3px;">
                                <div class="cal-sop-bar__fill" style="width:@card.SopCompletionPct%"></div>
                            </div>
                        </div>
                    }
                </div>
                @if (card.Status is "Confirmed" or "InProgress")
                {
                    var nextStatus = card.Status == "Confirmed" ? "InProgress" : "Completed";
                    var btnLabel   = card.Status == "Confirmed" ? "Start job"   : "Mark complete";
                    <div class="emp-task-card__actions">
                        <form method="post" asp-page-handler="UpdateStatus">
                            <input type="hidden" name="id"        value="@card.BookingId" />
                            <input type="hidden" name="status"    value="@nextStatus" />
                            <input type="hidden" name="weekStart" value="@weekStart.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="view"      value="week" />
                            <button type="submit" class="btn btn-sm">@btnLabel</button>
                        </form>
                        <a asp-page="/Admin/BookingDetail" asp-route-id="@card.BookingId" class="btn btn-sm">Details</a>
                    </div>
                }
                else
                {
                    <div class="emp-task-card__actions">
                        <a asp-page="/Admin/BookingDetail" asp-route-id="@card.BookingId" class="btn btn-sm">Details</a>
                    </div>
                }
            </div>
        }
    }

    if (!Model.Board.Days.Any(d => d.Bookings.Any()))
    {
        <div class="alert alert-info">No tasks assigned to you this week.</div>
    }
}

@* ═══════════════════════════════════════════════════════════════
   ADMIN RESOURCE GRID — Owner / Admin / Dispatcher
   ═══════════════════════════════════════════════════════════════ *@
else
{
    var grid = Model.ResourceGrid;

    <div class="page-header">
        <h1>Calendar</h1>
        @if (User.HasPermission(PermissionKeys.BookingsCreate))
        {
            <a asp-page="/Admin/Bookings" class="btn btn-sm">+ New Booking</a>
        }
    </div>

    @* ── Toolbar ── *@
    <div class="cal-toolbar">
        <div class="cal-view-pills">
            <a asp-page="/Admin/Kanban"
               asp-all-route-data='@(new Dictionary<string,string?>{{"weekStart",weekStart.ToString("yyyy-MM-dd")},{"view","week"}})'
               class="@(Model.View=="week"?"active":"")">Week</a>
            <a asp-page="/Admin/Kanban"
               asp-all-route-data='@(new Dictionary<string,string?>{{"weekStart",weekStart.ToString("yyyy-MM-dd")},{"view","day"},{"dayDate",(Model.DayView??weekStart).ToString("yyyy-MM-dd")}})'
               class="@(Model.View=="day"?"active":"")">Day</a>
            <a asp-page="/Admin/Kanban"
               asp-all-route-data='@(new Dictionary<string,string?>{{"weekStart",weekStart.ToString("yyyy-MM-dd")},{"view","month"}})'
               class="@(Model.View=="month"?"active":"")">Month</a>
        </div>

        @* Navigation *@
        @if (Model.View == "week")
        {
            <div class="cal-nav">
                <a asp-page="/Admin/Kanban"
                   asp-all-route-data='@(new Dictionary<string,string?>{{"weekStart",Model.PrevWeek.ToString("yyyy-MM-dd")},{"view","week"}})'
                   class="cal-nav-btn">&#8592;</a>
                <span class="cal-range-label">
                    @weekStart.ToString("d MMM") – @weekStart.AddDays(6).ToString("d MMM yyyy")
                </span>
                <a asp-page="/Admin/Kanban"
                   asp-all-route-data='@(new Dictionary<string,string?>{{"weekStart",Model.NextWeek.ToString("yyyy-MM-dd")},{"view","week"}})'
                   class="cal-nav-btn">&#8594;</a>
            </div>
        }
        else if (Model.View == "day")
        {
            var curDay = Model.DayView ?? weekStart;
            <div class="cal-nav">
                <a asp-page="/Admin/Kanban"
                   asp-all-route-data='@(new Dictionary<string,string?>{{"weekStart",Model.PrevDay.ToString("yyyy-MM-dd")},{"view","day"},{"dayDate",Model.PrevDay.ToString("yyyy-MM-dd")}})'
                   class="cal-nav-btn">&#8592;</a>
                <span class="cal-range-label">@curDay.ToString("dddd, d MMM yyyy")</span>
                <a asp-page="/Admin/Kanban"
                   asp-all-route-data='@(new Dictionary<string,string?>{{"weekStart",Model.NextDay.ToString("yyyy-MM-dd")},{"view","day"},{"dayDate",Model.NextDay.ToString("yyyy-MM-dd")}})'
                   class="cal-nav-btn">&#8594;</a>
            </div>
        }
        else if (Model.View == "month")
        {
            <div class="cal-nav">
                <a asp-page="/Admin/Kanban"
                   asp-all-route-data='@(new Dictionary<string,string?>{{"weekStart",Model.PrevMonth.ToString("yyyy-MM-dd")},{"view","month"}})'
                   class="cal-nav-btn">&#8592;</a>
                <span class="cal-range-label">@weekStart.ToString("MMMM yyyy")</span>
                <a asp-page="/Admin/Kanban"
                   asp-all-route-data='@(new Dictionary<string,string?>{{"weekStart",Model.NextMonth.ToString("yyyy-MM-dd")},{"view","month"}})'
                   class="cal-nav-btn">&#8594;</a>
            </div>
        }

        @* Employee filter *@
        <div style="display:flex;align-items:center;gap:0.4rem;">
            <input type="text" id="emp-filter" placeholder="Filter employees…"
                   class="text-input" style="min-width:160px;"
                   oninput="filterEmployeeColumns(this.value)" />
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @* ══════════════════════════════════
       DAY VIEW
       ══════════════════════════════════ *@
    @if (Model.View == "day" && grid != null)
    {
        var hours = Enumerable.Range(Model.GridStartHour, Model.GridEndHour - Model.GridStartHour).ToList();

        <div class="resource-grid-wrapper">
            <table class="resource-grid">
                <thead>
                    <tr>
                        <th class="resource-col-header resource-col-time-header">Time</th>
                        <th class="resource-col-header resource-col-unassigned-header">
                            Unassigned
                            @if (grid.Unassigned.Any())
                            {
                                <span class="resource-unassigned-badge">@grid.Unassigned.Count</span>
                            }
                        </th>
                        @foreach (var emp in grid.Employees)
                        {
                            <th class="resource-col-header @(emp.IsFree ? "resource-col-header--free" : "")"
                                data-emp-name="@emp.FullName.ToLower()">
                                <div class="resource-emp-name">@emp.FullName</div>
                                <div class="resource-emp-role">@emp.Role</div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var hour in hours)
                    {
                        <tr>
                            <td class="resource-cell resource-cell--time">@hour:00</td>

                            @* Unassigned cell *@
                            <td class="resource-cell resource-cell--unassigned">
                                @foreach (var card in grid.Unassigned.Where(c => c.Hour == hour))
                                {
                                    <a href="/Admin/BookingDetail/@card.BookingId"
                                       class="resource-card @StatusCss(card.Status)">
                                        <div class="resource-card__time">@card.Hour:00</div>
                                        <div class="resource-card__client">@card.ClientName</div>
                                        <div class="resource-card__meta">@card.ServiceType@(card.SiteName != null ? " · " + card.SiteName : "")</div>
                                    </a>
                                }
                            </td>

                            @* Employee cells *@
                            @foreach (var emp in grid.Employees)
                            {
                                var cellBookings = emp.Bookings.Where(c => c.Hour == hour).ToList();
                                <td class="resource-cell @(!cellBookings.Any() ? "resource-cell--free" : "")"
                                    data-emp-name="@emp.FullName.ToLower()">
                                    @foreach (var card in cellBookings)
                                    {
                                        <a href="/Admin/BookingDetail/@card.BookingId"
                                           class="resource-card @StatusCss(card.Status)">
                                            <div class="resource-card__time">@card.Hour:00</div>
                                            <div class="resource-card__client">@card.ClientName</div>
                                            <div class="resource-card__meta">@card.ServiceType@(card.SiteName != null ? " · " + card.SiteName : "")</div>
                                        </a>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @* ══════════════════════════════════
       WEEK VIEW
       ══════════════════════════════════ *@
    else if (Model.View == "week" && grid != null)
    {
        var days = Enumerable.Range(0, 7).Select(i => weekStart.AddDays(i)).ToList();

        <div class="resource-grid-wrapper">
            <table class="resource-grid">
                <thead>
                    <tr>
                        <th class="resource-col-header resource-col-time-header">Date</th>
                        <th class="resource-col-header resource-col-unassigned-header">
                            Unassigned
                            @if (grid.Unassigned.Any())
                            {
                                <span class="resource-unassigned-badge">@grid.Unassigned.Count</span>
                            }
                        </th>
                        @foreach (var emp in grid.Employees)
                        {
                            <th class="resource-col-header @(emp.IsFree ? "resource-col-header--free" : "")"
                                data-emp-name="@emp.FullName.ToLower()">
                                <div class="resource-emp-name">@emp.FullName</div>
                                <div class="resource-emp-role">@emp.Role</div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var day in days)
                    {
                        var isToday = day.Date == today;
                        <tr class="@(isToday ? "resource-row--today" : "")">
                            <td class="resource-cell resource-cell--time">
                                <div style="font-weight:600;color:#1a237e;">@day.ToString("ddd")</div>
                                <div>@day.ToString("d MMM")</div>
                            </td>

                            @* Unassigned cell *@
                            <td class="resource-cell resource-cell--unassigned">
                                @foreach (var card in grid.Unassigned.Where(c => c.Date.Date == day.Date))
                                {
                                    <a href="/Admin/BookingDetail/@card.BookingId"
                                       class="resource-chip @ChipCss(card.Status)">
                                        @card.Hour:00 @card.ClientName
                                    </a>
                                }
                            </td>

                            @* Employee cells *@
                            @foreach (var emp in grid.Employees)
                            {
                                var dayBookings = emp.Bookings.Where(c => c.Date.Date == day.Date).ToList();
                                <td class="resource-cell @(!dayBookings.Any() ? "resource-cell--free" : "")"
                                    data-emp-name="@emp.FullName.ToLower()">
                                    @foreach (var card in dayBookings)
                                    {
                                        <a href="/Admin/BookingDetail/@card.BookingId"
                                           class="resource-chip @ChipCss(card.Status)">
                                            @card.Hour:00 @card.ClientName
                                        </a>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @* ══════════════════════════════════
       MONTH VIEW
       ══════════════════════════════════ *@
    else if (Model.View == "month" && grid != null)
    {
        var firstOfMonth = new DateTime(weekStart.Year, weekStart.Month, 1);
        var lastOfMonth  = firstOfMonth.AddMonths(1).AddDays(-1);
        var days         = Enumerable.Range(0, (lastOfMonth - firstOfMonth).Days + 1)
                                     .Select(i => firstOfMonth.AddDays(i))
                                     .ToList();

        <div class="resource-grid-wrapper">
            <table class="resource-grid">
                <thead>
                    <tr>
                        <th class="resource-col-header resource-col-time-header">Date</th>
                        <th class="resource-col-header resource-col-unassigned-header">
                            Unassigned
                            @if (grid.Unassigned.Any())
                            {
                                <span class="resource-unassigned-badge">@grid.Unassigned.Count</span>
                            }
                        </th>
                        @foreach (var emp in grid.Employees)
                        {
                            <th class="resource-col-header @(emp.IsFree ? "resource-col-header--free" : "")"
                                data-emp-name="@emp.FullName.ToLower()">
                                <div class="resource-emp-name">@emp.FullName</div>
                                <div class="resource-emp-role">@emp.Role</div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var day in days)
                    {
                        var isToday = day.Date == today;
                        <tr class="@(isToday ? "resource-row--today" : "")">
                            <td class="resource-cell resource-cell--time">
                                <div style="font-weight:600;color:#1a237e;">@day.ToString("ddd")</div>
                                <div>@day.ToString("d MMM")</div>
                            </td>

                            @* Unassigned cell *@
                            <td class="resource-cell resource-cell--unassigned">
                                @{
                                    var unassignedCount = grid.Unassigned.Count(c => c.Date.Date == day.Date);
                                }
                                @if (unassignedCount > 0)
                                {
                                    <a href="/Admin/Kanban?view=day&weekStart=@day.ToString("yyyy-MM-dd")&dayDate=@day.ToString("yyyy-MM-dd")"
                                       class="resource-count">@unassignedCount</a>
                                }
                            </td>

                            @* Employee cells *@
                            @foreach (var emp in grid.Employees)
                            {
                                var count = emp.Bookings.Count(c => c.Date.Date == day.Date);
                                <td class="resource-cell @(count == 0 ? "resource-cell--free" : "")"
                                    data-emp-name="@emp.FullName.ToLower()">
                                    @if (count > 0)
                                    {
                                        <a href="/Admin/Kanban?view=day&weekStart=@day.ToString("yyyy-MM-dd")&dayDate=@day.ToString("yyyy-MM-dd")"
                                           class="resource-count">@count</a>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@section Scripts {
<script>
function filterEmployeeColumns(query) {
    const q = query.toLowerCase().trim();
    document.querySelectorAll('[data-emp-name]').forEach(el => {
        const name = el.getAttribute('data-emp-name') || '';
        const show = !q || name.includes(q);
        el.style.display = show ? '' : 'none';
    });
}
</script>
}