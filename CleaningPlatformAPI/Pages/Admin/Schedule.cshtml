@page
@model CleaningPlatformAPI.Pages.Admin.ScheduleModel
@{
    ViewData["Title"] = "Schedule";
    ViewData["ActivePage"] = "schedule";
}
<div class="page-header">
    <h1>Schedule</h1>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<section class="detail-section">
    <table class="admin-table">
        <thead>
        <tr>
            <th>Day</th>
            <th>Start</th>
            <th>End</th>
            <th>Capacity</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var d in Model.Schedule)
        {
            <tr>
                <td>@d.DayOfWeek</td>
                <td>@d.StartHour</td>
                <td>@d.EndHour</td>
                <td>@d.Capacity</td>
                <td>
                    <form method="post" asp-page-handler="DeleteDay" class="inline-form">
                        <input type="hidden" name="dayOfWeek" value="@d.DayOfWeek" />
                        <button type="submit" class="btn btn-sm">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

<section class="card-lite">
    <h2 class="section-title">Add Day</h2>
    <form method="post" asp-page-handler="AddDay" class="inline-form wrap">
        <input asp-for="DayInput.DayOfWeek" placeholder="Day (0-6)" class="small-input" />
        <input asp-for="DayInput.StartHour" placeholder="Start" class="small-input" />
        <input asp-for="DayInput.EndHour" placeholder="End" class="small-input" />
        <input asp-for="DayInput.Capacity" placeholder="Capacity" class="small-input" />
        <button type="submit" class="btn btn-sm">Add</button>
    </form>

    <h2 class="section-title">Update Day</h2>
    <form method="post" asp-page-handler="UpdateDay" class="inline-form wrap">
        <input asp-for="DayInput.DayOfWeek" placeholder="Day (0-6)" class="small-input" />
        <input asp-for="DayInput.StartHour" placeholder="Start" class="small-input" />
        <input asp-for="DayInput.EndHour" placeholder="End" class="small-input" />
        <input asp-for="DayInput.Capacity" placeholder="Capacity" class="small-input" />
        <button type="submit" class="btn btn-sm">Update</button>
    </form>
</section>
