@page
@model CleaningPlatformAPI.Pages.Admin.ScheduleModel
@{
    ViewData["Title"] = "Schedule";
    ViewData["ActivePage"] = "schedule";
    var dayNames = new[] { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
}
<div class="page-header">
    <h1>Schedule</h1>
    <button type="button" class="btn" id="add-day-btn">+ Add Day</button>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<section class="detail-section">
    <table class="admin-table">
        <thead><tr><th>Day</th><th>Start</th><th>End</th><th>Capacity</th></tr></thead>
        <tbody>
            @foreach (var d in Model.Schedule)
            {
                var dayName = d.DayOfWeek >= 0 && d.DayOfWeek <= 6 ? dayNames[d.DayOfWeek] : d.DayOfWeek.ToString();
                <tr class="schedule-row" data-day="@d.DayOfWeek" data-start="@d.StartHour" data-end="@d.EndHour" data-capacity="@d.Capacity" data-day-name="@dayName" title="Click to edit">
                    <td>@dayName</td><td>@d.StartHour</td><td>@d.EndHour</td><td>@d.Capacity</td>
                </tr>
            }
        </tbody>
    </table>
</section>

@* ── Date Overrides Section ── *@
<section class="detail-section" style="margin-top: 2rem;">
    <div class="page-header" style="margin-bottom:0;">
        <h2 class="section-title">Date Overrides</h2>
        <button type="button" class="btn btn-sm" id="open-override-modal">+ Add Override</button>
    </div>

    @if (Model.DateOverrides.Count == 0)
    {
        <div class="alert alert-info">No date overrides defined.</div>
    }
    else
    {
        <table class="admin-table">
            <thead><tr><th>Date</th><th>Start</th><th>End</th><th>Capacity</th><th>Closed</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var o in Model.DateOverrides)
                {
                    <tr>
                        <td>@o.Date.ToString("yyyy-MM-dd")</td>
                        <td>@(o.StartHour?.ToString() ?? "—")</td>
                        <td>@(o.EndHour?.ToString() ?? "—")</td>
                        <td>@(o.Capacity?.ToString() ?? "—")</td>
                        <td>@(o.IsFullyClosed ? "Yes" : "No")</td>
                        <td>
                            <button type="button" class="btn btn-sm" onclick="editOverride(@o.Id, '@o.Date.ToString("yyyy-MM-dd")', @(o.StartHour?.ToString() ?? "null"), @(o.EndHour?.ToString() ?? "null"), @(o.Capacity?.ToString() ?? "null"), @(o.IsFullyClosed.ToString().ToLower()))">Edit</button>
                            <form method="post" asp-page-handler="DeleteOverride" style="display:inline;">
                                <input type="hidden" name="id" value="@o.Id" />
                                <button type="submit" class="btn btn-sm" onclick="return confirm('Delete this override?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

<div id="schedule-modal" class="modal-backdrop" style="display:none;" onclick="if(event.target===this) closeScheduleModal()">
    <div class="modal-panel">
        <h2 class="section-title" id="schedule-modal-title">Add Day</h2>
        <form method="post" asp-page-handler="AddDay" id="schedule-add-form" class="form-grid two-col">
            <label>Day <select name="DayInput.DayOfWeek" id="add-day-of-week" class="status-select">@for (var i = 0; i < dayNames.Length; i++){<option value="@i">@dayNames[i]</option>}</select></label>
            <label>Start Hour <input name="DayInput.StartHour" id="add-start-hour" type="number" class="small-input" required /></label>
            <label>End Hour <input name="DayInput.EndHour" id="add-end-hour" type="number" class="small-input" required /></label>
            <label>Capacity <input name="DayInput.Capacity" id="add-capacity" type="number" class="small-input" required /></label>
            <div class="modal-actions full-span"><button type="submit" class="btn btn-sm">Add</button><button type="button" class="btn btn-sm" onclick="closeScheduleModal()">Cancel</button></div>
        </form>
        <form method="post" asp-page-handler="UpdateDay" id="schedule-update-form" class="form-grid two-col" style="display:none;">
            <input type="hidden" name="dayOfWeek" id="update-day-key" />
            <label>Day <select name="DayInput.DayOfWeek" id="update-day-of-week" class="status-select">@for (var i = 0; i < dayNames.Length; i++){<option value="@i">@dayNames[i]</option>}</select></label>
            <label>Start Hour <input name="DayInput.StartHour" id="update-start-hour" type="number" class="small-input" required /></label>
            <label>End Hour <input name="DayInput.EndHour" id="update-end-hour" type="number" class="small-input" required /></label>
            <label>Capacity <input name="DayInput.Capacity" id="update-capacity" type="number" class="small-input" required /></label>
            <div class="modal-actions full-span"><button type="submit" class="btn btn-sm">Update</button><button type="button" class="btn btn-sm" onclick="closeScheduleModal()">Cancel</button></div>
        </form>
        <form method="post" asp-page-handler="DeleteDay" id="schedule-delete-form" class="inline-form" style="display:none; margin-top:0.75rem;">
            <input type="hidden" name="dayOfWeek" id="delete-day-key" />
            <button type="submit" class="btn btn-sm" onclick="return confirm('Delete this day from schedule?')">Delete</button>
        </form>
    </div>
</div>

<div id="override-modal" class="modal-backdrop" style="display:none;" onclick="if(event.target===this) closeOverrideModal()">
    <div class="modal-panel">
        <h2 id="override-modal-title">Date Override</h2>
        <form method="post" asp-page-handler="SaveOverride" class="form-grid two-col">
            <input type="hidden" name="overrideId" id="override-id" />
            <label>Date <input type="date" asp-for="OverrideDate" class="date-input" required /></label>
            <label>Start hour <input asp-for="OverrideStartHour" type="number" class="small-input" /></label>
            <label>End hour <input asp-for="OverrideEndHour" type="number" class="small-input" /></label>
            <label>Capacity <input asp-for="OverrideCapacity" type="number" class="small-input" /></label>
            <label class="checkbox-label"><input asp-for="OverrideClosed" type="checkbox" /> Closed all day</label>
            <div class="modal-actions full-span"><button type="submit" class="btn btn-sm">Save Override</button><button type="button" class="btn btn-sm" onclick="closeOverrideModal()">Cancel</button></div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const scheduleModal = document.getElementById('schedule-modal');
    const overrideModal = document.getElementById('override-modal');
    const addForm = document.getElementById('schedule-add-form');
    const updateForm = document.getElementById('schedule-update-form');
    const deleteForm = document.getElementById('schedule-delete-form');

    window.closeScheduleModal = () => scheduleModal.style.display = 'none';
    window.closeOverrideModal = () => overrideModal.style.display = 'none';

    document.getElementById('add-day-btn').addEventListener('click', () => {
        document.getElementById('schedule-modal-title').textContent = 'Add Day';
        addForm.style.display = '';
        updateForm.style.display = 'none';
        deleteForm.style.display = 'none';
        addForm.reset();
        scheduleModal.style.display = 'flex';
    });

    document.querySelectorAll('.schedule-row').forEach(row => {
        row.style.cursor = 'pointer';
        row.addEventListener('click', () => {
            document.getElementById('schedule-modal-title').textContent = `Edit ${row.dataset.dayName}`;
            addForm.style.display = 'none';
            updateForm.style.display = '';
            deleteForm.style.display = '';
            document.getElementById('update-day-key').value = row.dataset.day;
            document.getElementById('update-day-of-week').value = row.dataset.day;
            document.getElementById('update-start-hour').value = row.dataset.start;
            document.getElementById('update-end-hour').value = row.dataset.end;
            document.getElementById('update-capacity').value = row.dataset.capacity;
            document.getElementById('delete-day-key').value = row.dataset.day;
            scheduleModal.style.display = 'flex';
        });
    });

    document.getElementById('open-override-modal').addEventListener('click', () => {
        document.getElementById('override-id').value = '';
        document.querySelector('#override-modal input[type="date"]').value = '';
        document.querySelector('[name="OverrideStartHour"]').value = '';
        document.querySelector('[name="OverrideEndHour"]').value = '';
        document.querySelector('[name="OverrideCapacity"]').value = '';
        document.querySelector('[name="OverrideClosed"]').checked = false;
        overrideModal.style.display = 'flex';
    });

    window.editOverride = (id, date, start, end, cap, closed) => {
        document.getElementById('override-id').value = id;
        document.querySelector('#override-modal input[type="date"]').value = date;
        document.querySelector('[name="OverrideStartHour"]').value = start;
        document.querySelector('[name="OverrideEndHour"]').value = end;
        document.querySelector('[name="OverrideCapacity"]').value = cap;
        document.querySelector('[name="OverrideClosed"]').checked = closed;
        overrideModal.style.display = 'flex';
    };
</script>
}