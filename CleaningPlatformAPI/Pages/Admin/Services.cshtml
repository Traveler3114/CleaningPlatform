@page
@model CleaningPlatformAPI.Pages.Admin.ServicesModel
@{
    ViewData["Title"] = "Services";
}
<h1>Services</h1>
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)) { <p style="color:#b00020;">@Model.ErrorMessage</p> }
<table>
<thead><tr><th>Code</th><th>Name</th><th>Active</th><th></th></tr></thead>
<tbody>
@foreach (var s in Model.Services)
{
    <tr>
        <td>@s.CatalogCode</td><td>@s.Name</td><td>@s.IsActive</td>
        <td>
            <form method="post" asp-page-handler="Delete" style="display:inline">
                <input type="hidden" name="id" value="@s.Id" />
                <button type="submit">Delete</button>
            </form>
        </td>
    </tr>
}
</tbody>
</table>
<h2>Create Service</h2>
<form method="post" asp-page-handler="Create">
    <input asp-for="NewService.CatalogCode" placeholder="Code" />
    <input asp-for="NewService.Name" placeholder="Name" />
    <button type="submit">Create</button>
</form>
<h2>Update Service</h2>
<form method="post" asp-page-handler="Update">
    <input type="number" name="id" placeholder="Service ID" />
    <input asp-for="EditService.CatalogCode" placeholder="Code" />
    <input asp-for="EditService.Name" placeholder="Name" />
    <button type="submit">Update</button>
</form>
