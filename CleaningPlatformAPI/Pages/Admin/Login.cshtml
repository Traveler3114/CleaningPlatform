@page
@model CleaningPlatformAPI.Pages.Admin.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Login</title>
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<main style="max-width:420px;margin:4rem auto;">
    <h1>Admin Login</h1>
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <p style="color:#b00020;">@Model.ErrorMessage</p>
    }
    <form method="post">
        <div>
            <label asp-for="Email"></label>
            <input asp-for="Email" required />
        </div>
        <div>
            <label asp-for="Password"></label>
            <input asp-for="Password" type="password" required />
        </div>
        <button type="submit">Sign in</button>
    </form>
</main>
</body>
</html>
