@page
@model CleaningPlatformAPI.Pages.Admin.ClientDetailModel
@{
    ViewData["Title"] = "Client Detail";
}
@if (Model.Client == null)
{
    <h1>Client not found</h1>
    return;
}
<h1>@Model.Client.ClientName</h1>
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)) { <p style="color:#b00020;">@Model.ErrorMessage</p> }
<form method="post" asp-page-handler="UpdateType">
    <input type="hidden" asp-for="Id" />
    <select name="newType"><option>OneTime</option><option>RepeatIndividual</option><option>RepeatBusiness</option></select>
    <button type="submit">Update Type</button>
</form>
<h2>Profile</h2>
<form method="post" asp-page-handler="UpdateProfile" id="profileForm">
    <input type="hidden" asp-for="Id" />
    <input asp-for="Profile.ClientName" />
    <input asp-for="Profile.Oib" placeholder="OIB" />
    <input asp-for="Profile.PaymentTerms" placeholder="Payment terms" />
    <textarea asp-for="Profile.Notes"></textarea>
    <input type="hidden" asp-for="ContactsJson" id="contactsJson" />
    <button type="submit">Save Profile</button>
</form>
<h3>Contacts</h3>
<table id="contactsTable"><tbody>
@for (var i = 0; i < Model.Client.Contacts.Count; i++)
{
    var c = Model.Client.Contacts[i];
    <tr>
        <td><input data-field="id" value="@c.Id" /></td>
        <td><input data-field="contactName" value="@c.ContactName" /></td>
        <td><input data-field="phone" value="@c.Phone" /></td>
        <td><input data-field="email" value="@c.Email" /></td>
        <td><input data-field="role" value="@c.Role" /></td>
        <td><input data-field="address" value="@c.Address" /></td>
        <td><input data-field="isPrimary" type="checkbox" @(c.IsPrimary ? "checked" : "") /></td>
        <td><input data-field="isActive" type="checkbox" @(c.IsActive ? "checked" : "") /></td>
        <td><button type="button" onclick="this.closest('tr').remove()">Remove</button></td>
    </tr>
}
</tbody></table>
<button type="button" id="addContact">Add Contact</button>
<h3>Sites</h3>
<ul>
@foreach (var s in Model.Client.Sites)
{
    <li>
        @s.SiteName - @s.Address (@(s.IsActive ? "Active" : "Inactive"))
        <form method="post" asp-page-handler="DeactivateSite" style="display:inline">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" name="siteId" value="@s.Id" />
            <button type="submit">Deactivate</button>
        </form>
    </li>
}
</ul>
<form method="post" asp-page-handler="AddSite">
    <input type="hidden" asp-for="Id" />
    <input asp-for="NewSite.SiteName" placeholder="Site name" />
    <input asp-for="NewSite.Address" placeholder="Address" />
    <input asp-for="NewSite.City" placeholder="City" />
    <button type="submit">Add Site</button>
</form>
@section Scripts {
<script>
(() => {
  const tableBody = document.querySelector('#contactsTable tbody');
  const addBtn = document.getElementById('addContact');
  const form = document.getElementById('profileForm');
  addBtn.addEventListener('click', () => {
    const tr = document.createElement('tr');
    tr.innerHTML = `<td><input data-field="id" /></td><td><input data-field="contactName" /></td><td><input data-field="phone" /></td><td><input data-field="email" /></td><td><input data-field="role" /></td><td><input data-field="address" /></td><td><input data-field="isPrimary" type="checkbox" /></td><td><input data-field="isActive" type="checkbox" checked /></td><td><button type="button">Remove</button></td>`;
    tr.querySelector('button').addEventListener('click', () => tr.remove());
    tableBody.appendChild(tr);
  });

  form.addEventListener('submit', () => {
    const contacts = Array.from(tableBody.querySelectorAll('tr')).map(row => {
      const q = (name) => row.querySelector(`[data-field="${name}"]`);
      const id = q('id').value;
      return {
        id: id ? parseInt(id, 10) : null,
        contactName: q('contactName').value || '',
        phone: q('phone').value || '',
        email: q('email').value || null,
        role: q('role').value || null,
        address: q('address').value || null,
        isPrimary: q('isPrimary').checked,
        isActive: q('isActive').checked
      };
    });
    document.getElementById('contactsJson').value = JSON.stringify(contacts);
  });
})();
</script>
}
