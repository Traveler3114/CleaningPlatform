@page "{id:int}"
@model CleaningPlatformAPI.Pages.Admin.BookingDetailModel
@using CleaningPlatformAPI.Common
@using CleaningPlatformAPI.Extensions
@{
    ViewData["Title"] = Model.Booking != null ? $"Booking #{Model.Booking.Id}" : "Booking Detail";
    ViewData["ActivePage"] = "bookings";
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert" style="background:#fce4ec;color:#c62828;border:1px solid #ef9a9a;">
        @Model.ErrorMessage
    </div>
}

@if (Model.Booking == null)
{
    <div class="alert alert-info">Booking not found.</div>
    return;
}

@* ===== Booking Header ===== *@
<section class="detail-section">
    <div class="page-header">
        <div>
            <h1>Booking #@Model.Booking.Id</h1>
            <p>@Model.Booking.Date.ToString("yyyy-MM-dd") at @Model.Booking.Hour:00</p>
        </div>
        <span class="badge badge-@Model.Booking.Status.ToLower()">@Model.Booking.Status</span>
    </div>

    <div class="inline-form" style="margin-top:0.7rem; flex-wrap:wrap;">
        <form method="post" asp-page-handler="UpdateStatus" style="display:contents;">
            <input type="hidden" name="id" value="@Model.Booking.Id" />
            <select name="status" class="status-select">
                @foreach (var s in new[] { "Pending", "Confirmed", "InProgress", "Completed", "Cancelled" })
                {
                    if (Model.Booking.Status == s)
                    {
                        <option value="@s" selected="selected">@s</option>
                    }
                    else
                    {
                        <option value="@s">@s</option>
                    }
                }
            </select>
            <button type="submit" class="btn btn-sm">Save</button>
        </form>

        @if (Model.Booking.Status == "Completed")
        {
            <form method="post" asp-page-handler="GenerateInvoice" style="display:contents;">
                <input type="hidden" name="id" value="@Model.Booking.Id" />
                <button type="submit" class="btn btn-sm">Generate Invoice</button>
            </form>
        }
    </div>
</section>

@* ===== Client Info ===== *@
<section class="detail-section">
    <h2 class="section-title">Client Info</h2>
    <p>
        <strong>Name:</strong>
        @if (Model.Booking.ClientId > 0)
        {
            <a href="/Admin/ClientDetail?id=@Model.Booking.ClientId">@Model.Booking.ClientName</a>
        }
        else
        {
            @Model.Booking.ClientName
        }
    </p>
    <p><strong>Phone:</strong> @(Model.Booking.ClientPhone ?? "-")</p>
    <p><strong>Email:</strong> @(Model.Booking.ClientEmail ?? "-")</p>
</section>

@* ===== Employee Assignment ===== *@
<section class="detail-section">
    <h2 class="section-title">Employee Assignments</h2>
    @if (Model.Booking.AssignedEmployees.Any())
    {
        <ul>
            @foreach (var a in Model.Booking.AssignedEmployees)
            {
                <li style="margin-bottom:0.4rem;">
                    @a.FullName (@a.Role)
                    @if (User.HasPermission(PermissionKeys.BookingsEdit))
                    {
                        <form method="post" asp-page-handler="RemoveAssignment" style="display:inline; margin-left:0.5rem;">
                            <input type="hidden" name="id" value="@Model.Booking.Id" />
                            <input type="hidden" name="assignmentId" value="@a.AssignmentId" />
                            <button type="submit" class="btn btn-sm">Remove</button>
                        </form>
                    }
                </li>
            }
        </ul>
    }
    else
    {
        <p><strong>Current:</strong> Unassigned</p>
    }

    @if (User.HasPermission(PermissionKeys.BookingsEdit))
    {
        <form method="post" asp-page-handler="AddAssignment" class="inline-form" style="flex-wrap:wrap;">
            <input type="hidden" name="id" value="@Model.Booking.Id" />
            <select name="employeeId" class="status-select" required>
                <option value="">Select employee</option>
                @foreach (var e in Model.ActiveEmployees)
                {
                    <option value="@e.Id">@e.FullName (@e.Role)</option>
                }
            </select>
            <button type="submit" class="btn btn-sm">Add</button>
        </form>
    }
</section>

@* ===== Services ===== *@
<section class="detail-section">
    <h2 class="section-title">Services</h2>

    @if (Model.Booking.Services.Any())
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Quantity</th>
                    <th>Estimated Price</th>
                    <th>Final Price</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Booking.Services)
                {
                    <tr>
                        <td>@s.ServiceName</td>
                        <td>@s.Quantity</td>
                        <td>@(s.EstimatedPrice?.ToString("0.00") ?? "-")</td>
                        <td>
                            <form method="post" asp-page-handler="UpdateServicePrice" class="inline-form">
                                <input type="hidden" name="id" value="@Model.Booking.Id" />
                                <input type="hidden" name="serviceId" value="@s.Id" />
                                <input name="finalPrice" type="number" step="0.01" class="small-input"
                                       value="@s.FinalPrice" placeholder="Final price" />
                                <button type="submit" class="btn btn-sm">Save</button>
                            </form>
                        </td>
                        <td>@(s.Notes ?? "-")</td>
                        <td>
                            <form method="post" asp-page-handler="RemoveService"
                                  onsubmit="return confirm('Remove this service?');">
                                <input type="hidden" name="id" value="@Model.Booking.Id" />
                                <input type="hidden" name="serviceId" value="@s.Id" />
                                <button type="submit" class="btn btn-sm">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">No services assigned.</div>
    }

    <div class="card-lite" style="margin-top:1rem;">
        <h3 class="section-title">+ Add Service</h3>
        <form method="post" asp-page-handler="AddService">
            <input type="hidden" name="id" value="@Model.Booking.Id" />
            <div class="inline-form" style="flex-wrap:wrap;">
                <select name="serviceCatalogId" class="status-select">
                    <option value="">Select service</option>
                    @foreach (var s in Model.ServiceCatalog)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
                <input name="quantity" type="number" min="0.01" step="0.01" value="1"
                       class="small-input" placeholder="Qty" />
                <input name="estimatedPrice" type="number" min="0" step="0.01"
                       class="small-input" placeholder="Estimated" />
                <input name="notes" type="text" class="text-input" placeholder="Notes (optional)" />
                <button type="submit" class="btn btn-sm">Add Service</button>
            </div>
        </form>
    </div>
</section>


@* ===== SOPs ===== *@
<section class="detail-section">
    <h2 class="section-title">SOPs</h2>
    @if (!Model.BookingSops.Any())
    {
        <div class="alert alert-info">No SOPs assigned.</div>
    }
    else
    {
        @foreach (var sop in Model.BookingSops)
        {
            <div class="card-lite" style="margin-bottom:1rem;">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <strong>@sop.SopName</strong>
                    <span class="badge">@sop.CompletedItems / @sop.TotalItems complete</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(sop.CustomInstructions))
                {
                    <p style="margin-top:0.5rem; font-size:0.875rem;">
                        <em>@sop.CustomInstructions</em>
                    </p>
                }
                @if (sop.ChecklistItems.Any())
                {
                    <ul style="margin-top:0.75rem; list-style:none; padding:0;">
                        @foreach (var item in sop.ChecklistItems)
                        {
                            <li style="display:flex; align-items:flex-start; gap:0.5rem; padding:0.35rem 0; border-bottom:1px solid #f0f0f0;">
                                @if (User.HasPermission(PermissionKeys.BookingsEdit) && Model.Booking.AssignedEmployees.Any())
                                {
                                    var primaryAssignment = Model.Booking.AssignedEmployees.OrderBy(a => a.AssignmentId).First();
                                    <form method="post" asp-page-handler="CompleteChecklistItem" style="display:contents;">
                                        <input type="hidden" name="id" value="@Model.Booking.Id" />
                                        <input type="hidden" name="assignmentId" value="@primaryAssignment.AssignmentId" />
                                        <input type="hidden" name="itemId" value="@item.ChecklistItemId" />
                                        <input type="hidden" name="isCompleted" value="@(!item.IsCompleted)" />
                                        <input type="checkbox" checked="@item.IsCompleted" onchange="this.form.submit()" style="margin-top:2px; cursor:pointer;" />
                                    </form>
                                }
                                else
                                {
                                    <input type="checkbox" checked="@item.IsCompleted" disabled style="margin-top:2px;" />
                                }
                                <span style="@(item.IsCompleted ? "text-decoration:line-through; color:#888;" : "")">
                                    @item.ItemText
                                    @if (item.IsRequired)
                                    {
                                        <span style="color:#c62828; font-size:0.75rem; margin-left:4px;">*</span>
                                    }
                                </span>
                            </li>
                        }
                    </ul>
                }
            </div>
        }
    }

    @if (User.HasPermission(PermissionKeys.BookingsEdit))
    {
        <form method="post" asp-page-handler="AssignSop" class="inline-form" style="margin-top:1rem;">
            <input type="hidden" name="id" value="@Model.Booking.Id" />
            <select name="sopTemplateId" class="status-select" required>
                <option value="">Assign SOP template</option>
                @foreach (var template in Model.SopTemplates.Where(t => t.IsActive))
                {
                    <option value="@template.Id">@template.Name (@template.ServiceType)</option>
                }
            </select>
            <button type="submit" class="btn btn-sm">Assign SOP</button>
        </form>
    }
</section>

<a asp-page="/Admin/Bookings" class="btn btn-sm" style="margin-top:0.5rem;">← Back</a>
