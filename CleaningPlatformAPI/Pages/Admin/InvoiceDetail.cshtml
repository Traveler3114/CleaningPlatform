@page
@model CleaningPlatformAPI.Pages.Admin.InvoiceDetailModel
@{
    ViewData["Title"] = "Invoice Detail";
    ViewData["ActivePage"] = "invoices";
}
@if (Model.Invoice == null)
{
    <div class="alert alert-info">Invoice not found.</div>
    return;
}

<div class="page-header">
    <div>
        <h1>@Model.Invoice.InvoiceNumber</h1>
        <span class="badge badge-@Model.Invoice.Status.ToLower()">@Model.Invoice.Status</span>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<section class="stats-grid">
    <div class="kpi-card"><span>Total</span><strong>@Model.Invoice.TotalAmount</strong></div>
    <div class="kpi-card"><span>Balance due</span><strong>@Model.Invoice.BalanceDue</strong></div>
</section>

<section class="card-lite">
    <h2 class="section-title">Update status</h2>
    <form method="post" asp-page-handler="UpdateStatus" class="inline-form wrap">
        <input type="hidden" asp-for="Id" />
        <select name="status" class="status-select">
            <option>Draft</option>
            <option>Sent</option>
            <option>PartiallyPaid</option>
            <option>Paid</option>
            <option>Overdue</option>
            <option>WrittenOff</option>
        </select>
        <button type="submit" class="btn btn-sm">Update Status</button>
    </form>
</section>

<section class="card-lite">
    <h2 class="section-title">Record payment</h2>
    <form method="post" asp-page-handler="RecordPayment" class="form-grid two-col">
        <input type="hidden" asp-for="Id" />
        <label>
            Payment date
            <input type="date" name="paymentDate" class="text-input" required />
        </label>
        <label>
            Amount
            <input type="number" name="amount" step="0.01" placeholder="Amount" class="text-input" required />
        </label>
        <label>
            Method
            <input name="method" placeholder="Method" value="BankTransfer" class="text-input" />
        </label>
        <label>
            Reference
            <input name="reference" placeholder="Reference" class="text-input" />
        </label>
        <label class="full-span">
            Notes
            <input name="notes" placeholder="Notes" class="text-input" />
        </label>
        <div class="modal-actions">
            <button type="submit" class="btn btn-sm">Record Payment</button>
        </div>
    </form>
</section>
