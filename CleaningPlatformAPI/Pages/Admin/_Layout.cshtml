<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Vehicle Cleaning Admin</title>
    <link rel="stylesheet" href="~/css/style.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="admin-header">
        <div class="header-inner">
            <span class="brand">🚗 Vehicle Cleaning Admin</span>
            <nav class="main-nav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-page="/Admin/Index"
                       class="nav-link @(ViewData["ActivePage"]?.ToString() == "daily" ? "active" : "")">Daily View</a>
                    <a asp-page="/Admin/Bookings"
                       class="nav-link @(ViewData["ActivePage"]?.ToString() == "bookings" ? "active" : "")">Bookings</a>
                    <a asp-page="/Admin/Clients"
                       class="nav-link @(ViewData["ActivePage"]?.ToString() == "clients" ? "active" : "")">Clients</a>
                }
            </nav>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="user-pill">
                    <div class="user-pill-info">
                        <span class="user-pill-name">@User.Identity.Name</span>
                        <span class="user-pill-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                    </div>
                    <form method="post" asp-page="/Admin/Login" asp-page-handler="Logout" style="margin:0;">
                        <button type="submit" class="logout-btn">Sign out</button>
                    </form>
                </div>
            }
        </div>
    </header>

    <main class="admin-main">
        @RenderBody()
    </main>

    <footer class="admin-footer">
        <p>&copy; @DateTime.Now.Year Vehicle Cleaning Admin</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
