<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="~/css/admin.css" /> @* Matches the theme variables *@
</head>
<body>
    <header class="admin-header">
        <nav class="header-inner">
            @* Use .header-inner for flex spacing *@
            <div class="brand-group">
                <strong class="brand">🚗 Admin Portal</strong>
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="main-nav">
                        <a asp-page="/Admin/Index" class="nav-link">Dashboard</a>
                        <a asp-page="/Admin/Bookings" class="nav-link">Bookings</a>
                        <a asp-page="/Admin/Clients" class="nav-link">Clients</a>
                    </div>
                }
            </div>
            <div class="user-pill">
                @if (User.Identity.IsAuthenticated)
                {
                    <form method="post" asp-page="/Admin/Login" asp-page-handler="Logout">
                        <button type="submit" class="btn btn-sm btn-outline-light">Sign Out</button>
                    </form>
                }
            </div>
        </nav>
    </header>

    <main class="admin-main">
        @* Adds padding and centering from admin.css *@
        @RenderBody()
    </main>
</body>
</html>