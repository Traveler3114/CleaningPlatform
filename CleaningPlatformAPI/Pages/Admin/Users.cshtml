@page
@model CleaningPlatformAPI.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Users";
    ViewData["ActivePage"] = "users";
}
<div class="page-header">
    <h1>Users</h1>
    <button type="button" class="btn" id="new-user-btn">+ New User</button>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<section class="detail-section">
    <table class="admin-table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Username</th>
            <th>Role</th>
            <th>Active</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var u in Model.Users)
        {
            <tr class="@(!u.IsActive ? "row-inactive" : "") user-row"
                data-user-id="@u.Id"
                data-username="@u.Username"
                data-fullname="@($"{u.FirstName} {u.LastName}")"
                data-role="@u.Role"
                data-active="@u.IsActive.ToString().ToLowerInvariant()"
                title="Click for user details">
                <td>@u.FirstName @u.LastName</td>
                <td>@u.Username</td>
                <td><span class="badge badge-@u.Role.ToLower()">@u.Role</span></td>
                <td>
                    <form method="post" asp-page-handler="Toggle" class="inline-form">
                        <input type="hidden" name="id" value="@u.Id" />
                        <label class="checkbox-label">
                            <input type="checkbox" class="checkbox" @(u.IsActive ? "checked" : null) onchange="this.form.submit()" />
                            Active
                        </label>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

<div id="new-user-modal" class="modal-backdrop" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); align-items:center; justify-content:center; z-index:1000;"
     onclick="if(event.target===this) closeUserModal()">
    <div class="modal-panel" style="background:white; border-radius:8px; width:min(900px,95vw); max-height:90vh; overflow:auto; padding:1rem;">
        <h2 class="section-title">Create User</h2>
        <form method="post" asp-page-handler="Create" class="form-grid two-col">
            <label>
                First name
                <input asp-for="NewUser.FirstName" placeholder="First name" class="text-input" required />
            </label>
            <label>
                Last name
                <input asp-for="NewUser.LastName" placeholder="Last name" class="text-input" required />
            </label>
            <label>
                Password
                <input asp-for="NewUser.Password" type="password" placeholder="Password" class="text-input" required />
            </label>
            <label>
                Role
                <select asp-for="NewUser.Role" class="status-select">
                    @foreach (var r in Model.AvailableRoles)
                    {
                        <option>@r.Name</option>
                    }
                </select>
            </label>
            <div class="modal-actions full-span">
                <button type="submit" class="btn btn-sm">Create</button>
                <button type="button" class="btn btn-sm" onclick="closeUserModal()">Cancel</button>
            </div>
        </form>
    </div>
</div>

<div id="user-modal" class="modal-backdrop" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); align-items:center; justify-content:center; z-index:1000;"
     onclick="if(event.target===this) closeDetailUserModal()">
    <div class="modal-panel" style="background:white; border-radius:8px; width:min(700px,95vw); max-height:90vh; overflow:auto; padding:1rem;">
        <h2 class="section-title">User Details</h2>

        <div class="form-grid two-col">
            <label>
                Username
                <input id="modal-username" class="text-input" readonly />
            </label>
            <label>
                Full Name
                <input id="modal-fullname" class="text-input" readonly />
            </label>
            <label>
                Role
                <input id="modal-role" class="text-input" readonly />
            </label>
            <label>
                Active
                <input id="modal-active" class="text-input" readonly />
            </label>
        </div>

        <h3 class="section-title" style="margin-top:1rem;">Reset Password</h3>
        <form method="post" asp-page-handler="ResetPassword" class="form-grid">
            <input type="hidden" name="userId" id="modal-user-id" />
            <label>
                New Password
                <input type="password" name="newPassword" placeholder="New password" class="text-input" required />
            </label>
            <div class="modal-actions">
                <button type="submit" class="btn btn-sm">Reset Password</button>
                <button type="button" class="btn btn-sm" onclick="closeDetailUserModal()">Close</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const newUserModal = document.getElementById('new-user-modal');
    const userModal = document.getElementById('user-modal');

    const modalUserId = document.getElementById('modal-user-id');
    const modalUsername = document.getElementById('modal-username');
    const modalFullname = document.getElementById('modal-fullname');
    const modalRole = document.getElementById('modal-role');
    const modalActive = document.getElementById('modal-active');

    document.getElementById('new-user-btn').addEventListener('click', () => {
        newUserModal.style.display = 'flex';
    });
    window.closeUserModal = () => {
        newUserModal.style.display = 'none';
    };

    window.closeDetailUserModal = () => {
        userModal.style.display = 'none';
    };

    document.querySelectorAll('.user-row').forEach(row => {
        row.style.cursor = 'pointer';
        row.addEventListener('click', (event) => {
            if (event.target.closest('form')) return;

            modalUserId.value = row.dataset.userId || '';
            modalUsername.value = row.dataset.username || '';
            modalFullname.value = row.dataset.fullname || '';
            modalRole.value = row.dataset.role || '';
            modalActive.value = row.dataset.active === 'true' ? 'Yes' : 'No';

            userModal.style.display = 'flex';
        });
    });
})();
</script>
}
